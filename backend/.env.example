PORT=3000
# Required — the server refuses to start without it. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Required, and must be a DIFFERENT value from JWT_SECRET — used to HMAC-sign
# the trace-event hash chain so a leaked JWT_SECRET alone can't be used to
# forge a "valid" tampered chain. Generate the same way as JWT_SECRET above.
LEDGER_SIGNING_KEY=
# Leave DATABASE_URL unset to run with the in-memory store (no Postgres needed).
DATABASE_URL=postgres://tracechain:tracechain_dev@localhost:5432/tracechain
NODE_ENV=development
PUBLIC_ORIGIN=http://localhost:5173
# Only relevant when NODE_ENV=production: set to "true" to seed the demo
# accounts (including a demo ADMIN login) anyway, for a hosted demo. Leave
# unset for a real deployment.
SEED_DEMO_DATA=
